{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "test-blog-cms",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1
    }
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "test-blog-cms-db",
      "database_id": "57879c1b-9faf-4f4f-95af-f2a009295f73",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "test-blog-assets"
    }
  ],
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "test-cms-content"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "vars": {
    "ENVIRONMENT": "production",
    "ASSET_BASE_URL": "https://test-cms.solberg.is"
  }
}
