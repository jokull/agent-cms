---
import ResponsiveImage from "../ResponsiveImage.astro";

interface Props {
  data: {
    headline: string;
    subheadline?: string;
    backgroundImage?: {
      responsiveImage?: {
        src: string;
        srcSet?: string;
        width?: number;
        height?: number;
        alt?: string;
      };
    };
    ctaText?: string;
    ctaUrl?: string;
  };
}

const { data } = Astro.props;
---

<section class="hero">
  {data.backgroundImage?.responsiveImage && (
    <div class="hero-bg">
      <ResponsiveImage data={data.backgroundImage.responsiveImage} loading="eager" />
    </div>
  )}
  <div class="hero-content">
    <h1>{data.headline}</h1>
    {data.subheadline && <p class="subheadline">{data.subheadline}</p>}
    {data.ctaText && data.ctaUrl && (
      <a href={data.ctaUrl} class="cta">{data.ctaText}</a>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 4rem 2rem;
    text-align: center;
    background: #1a1a2e;
    color: white;
    border-radius: 8px;
    overflow: hidden;
    margin: 2rem 0;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    opacity: 0.3;
  }
  .hero-bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-content {
    position: relative;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin: 0 0 1rem;
  }
  .subheadline {
    font-size: 1.25rem;
    opacity: 0.9;
    margin: 0 0 2rem;
  }
  .cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: white;
    color: #1a1a2e;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
  }
</style>
