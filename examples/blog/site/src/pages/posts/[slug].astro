---
import Base from "../../layouts/Base.astro";
import StructuredText from "../../components/StructuredText.astro";
import { env } from "cloudflare:workers";
import { gqlFetch } from "../../graphql/client";
import { POST_BY_SLUG_QUERY } from "../../graphql/queries";

const { slug } = Astro.params;
const cms = env.CMS;

const data = await gqlFetch(cms, POST_BY_SLUG_QUERY, { slug: slug! });
const post = data.post;

if (!post) {
  return Astro.redirect("/404");
}
---

<Base seoTags={post._seoMetaTags}>
  <article class="post">
    <header>
      {post.category && (
        <a href={`/categories/${post.category.slug}`} class="category">
          {post.category.name}
        </a>
      )}
      <h1>{post.title}</h1>
      <div class="meta">
        {post.author && (
          <div class="author">
            <span>{post.author.name}</span>
          </div>
        )}
        {post.publishedDate && (
          <time datetime={post.publishedDate}>
            {new Date(post.publishedDate).toLocaleDateString("en", { year: "numeric", month: "long", day: "numeric" })}
          </time>
        )}
        {post.readingTime && <span>{post.readingTime} min read</span>}
        {post.featured && <span class="featured-badge">Featured</span>}
      </div>
    </header>

    {post.content && (
      <div class="content">
        <StructuredText data={post.content} />
      </div>
    )}
  </article>
</Base>

<style>
  .post { max-width: 720px; margin: 0 auto; }

  header { margin-bottom: 2rem; }

  .category {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
    text-decoration: none;
  }

  h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    margin: 0.5rem 0 1rem;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.9rem;
    color: #666;
  }

  .author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .featured-badge {
    background: #fef3c7;
    color: #92400e;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .content :global(p) { margin: 1rem 0; }
  .content :global(h2) { margin: 2rem 0 0.5rem; font-size: 1.5rem; }
  .content :global(h3) { margin: 1.5rem 0 0.5rem; font-size: 1.25rem; }
  .content :global(blockquote) {
    border-left: 3px solid #ddd;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: #555;
  }
  .content :global(pre) { margin: 1.5rem 0; }
  .content :global(code) {
    background: #f1f5f9;
    padding: 0.15rem 0.35rem;
    border-radius: 3px;
    font-size: 0.9em;
  }
  .content :global(pre code) {
    background: none;
    padding: 0;
  }
</style>
