{
  "name": "test-i18n-site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && echo '_worker.js' > dist/.assetsignore",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "introspect": "gql.tada generate-schema 'http://localhost:8787/graphql' --output ../schema.graphql",
    "generate": "gql.tada generate-output",
    "graphql:check": "gql.tada check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.1",
    "astro": "^6.0.4",
    "gql.tada": "^1.8.0",
    "graphql": "^16.13.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0"
  }
}
