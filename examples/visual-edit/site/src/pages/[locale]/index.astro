---
import Base from "../../layouts/Base.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import EditablePage from "../../components/EditablePage";
import { graphqlQuery } from "../../graphql/client";
import { PAGE_QUERY, type PageData } from "../../graphql/queries";

const locale = Astro.params.locale ?? "en";

const url = new URL(Astro.request.url);
const editMode = url.searchParams.get("edit") === "true";

const data = await graphqlQuery<PageData>(PAGE_QUERY, {
  locale,
  fallbackLocales: ["en"],
}, { includeDrafts: editMode });

const page = data.page;
const cmsEndpoint = import.meta.env.CMS_ENDPOINT ?? "http://localhost:8787";
const writeKey = import.meta.env.CMS_WRITE_KEY ?? "dev";
---
<Base title={page?.title ?? "Visual Edit Example"}>
  <LanguageSwitcher currentLocale={locale} />
  {page ? (
    <EditablePage
      client:load
      page={page}
      locale={locale}
      editMode={editMode}
      cmsEndpoint={cmsEndpoint}
      writeKey={writeKey}
    />
  ) : (
    <p>No page content found. Run the seed script first.</p>
  )}
</Base>
