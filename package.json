{
  "name": "agent-cms",
  "version": "0.1.0",
  "description": "Agent-first headless CMS for Cloudflare Workers. Schema, content, and assets via MCP. GraphQL delivery.",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "wrangler dev",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint --type-check src/",
    "typecheck": "tsc --noEmit",
    "bench:blog": "node scripts/bench-blog.mjs",
    "dato:import": "node scripts/dato-import/cli.mjs",
    "prepublishOnly": "npm run build",
    "db:migrate": "wrangler d1 migrations apply agent-cms-db --local",
    "prepare": "effect-language-service patch"
  },
  "keywords": [
    "cms",
    "headless-cms",
    "mcp",
    "cloudflare-workers",
    "d1",
    "graphql",
    "agent",
    "ai"
  ],
  "author": "Jokull Solberg <jokull@solberg.is>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jokull/agent-cms.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "@effect/ai": "^0.34.0",
    "@effect/cli": "^0.74.0",
    "@effect/experimental": "^0.59.0",
    "@effect/platform": "^0.95.0",
    "@effect/platform-node": "^0.105.0",
    "@effect/printer": "^0.48.0",
    "@effect/printer-ansi": "^0.48.0",
    "@effect/rpc": "^0.74.0",
    "@effect/sql": "^0.50.0",
    "@effect/sql-d1": "^0.48.0",
    "effect": "^3.20.0",
    "graphql": "^16.13.1",
    "graphql-yoga": "^5.18.1",
    "slugify": "^1.6.8",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@effect/language-service": "^0.80.0",
    "@effect/sql-sqlite-node": "^0.51.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "miniflare": "^4.20260312.1",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  }
}
