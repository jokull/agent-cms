{
  "name": "@agent-cms/visual-edit",
  "version": "0.1.0",
  "description": "Visual editing overlay for agent-cms — image replacement and markdown text editing",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cms",
    "visual-editing",
    "agent-cms"
  ],
  "author": "Jokull Solberg <jokull@solberg.is>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jokull/agent-cms.git",
    "directory": "packages/visual-edit"
  },
  "dependencies": {
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  }
}
